<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Microphone access (Block A: MicCapture via AVAudioEngine). -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Network: relay (Cloudflare) + Deepgram WS. -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Electron / V8 JIT. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Required to load the bundled Swift sidecar binary (separate signing identity in dev, hardened-runtime tolerant). -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Lets us pass DYLD_* / etc. to the spawned sidecar if ever needed. -->
    <key>com.apple.security.cs.allow-dyld-environment-variables</key>
    <true/>
</dict>
</plist>

{
  "name": "prompty-relay",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker relay for Prompty: Google auth + Deepgram key minting + per-user rate limiting.",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx test/smoke.ts",
    "smoke:google-jwt": "tsx test/smoke-google-jwt.ts",
    "test": "npm run typecheck && npm run smoke:google-jwt"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/node": "^25.9.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  }
}

{
  "manifest_version": 3,
  "name": "Prompty",
  "version": "0.1.0",
  "description": "Real-time teleprompter that nudges you during calls.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "scripting",
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "ws://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Prompty — click before Start to enable tab capture"
  },
  "commands": {
    "request-nudge": {
      "suggested_key": {
        "default": "Alt+Shift+Space",
        "mac": "Alt+Shift+Space"
      },
      "description": "Ask Prompty: what should I ask next?"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["sidebar.css"],
      "matches": ["https://meet.google.com/*"]
    }
  ]
}

{
  "name": "prompty-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=../.env --import tsx --watch server.ts",
    "start": "node --env-file-if-exists=../.env --import tsx server.ts",
    "smoke:transcribe": "node --env-file-if-exists=../.env --import tsx test-fixtures/smoke-transcribe.ts",
    "smoke:transcribe-mock": "PROMPTY_MOCK_DEEPGRAM=1 node --env-file-if-exists=../.env --import tsx test-fixtures/smoke-transcribe.ts",
    "smoke:agent": "node --env-file-if-exists=../.env --import tsx test-fixtures/smoke-agent.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.10",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
